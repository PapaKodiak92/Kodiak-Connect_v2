# Kodiak Connect v2 staging environment example
# Copy this file outside the repo for real deployments.

COMPOSE_PROJECT_NAME=kodiak_connect_v2_staging

POSTGRES_DB=synapse
POSTGRES_USER=synapse
POSTGRES_PASSWORD=CHANGE_ME_STAGING_POSTGRES_PASSWORD

SYNAPSE_SERVER_NAME=v2.kodiak-connect.com
SYNAPSE_PUBLIC_BASEURL=https://matrix-v2.kodiak-connect.com/
SYNAPSE_REPORT_STATS=no
SYNAPSE_REGISTRATION_SHARED_SECRET=CHANGE_ME_STAGING_REGISTRATION_SECRET
SYNAPSE_MACAROON_SECRET_KEY=CHANGE_ME_STAGING_MACAROON_SECRET
SYNAPSE_FORM_SECRET=CHANGE_ME_STAGING_FORM_SECRET

TURN_DOMAIN=turn-v2.kodiak-connect.com
TURN_SHARED_SECRET=CHANGE_ME_STAGING_TURN_SECRET
