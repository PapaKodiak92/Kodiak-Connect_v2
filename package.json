{
  "name": "kodiak-connect-v2",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:init": "cap init \"Kodiak Connect\" com.kodiakholdings.kodiakconnect --web-dir dist",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run build && cap sync android",
    "cap:open:android": "cap open android",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:signer:generate": "tauri signer generate -w ~/.tauri/kodiak-connect-v2.key",
    "check": "tsc -b"
  },
  "dependencies": {
    "@capacitor/android": "latest",
    "@capacitor/core": "latest",
    "@tauri-apps/api": "latest",
    "@tauri-apps/plugin-updater": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "latest",
    "@tauri-apps/cli": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
