{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kodiak Connect",
  "version": "0.2.7",
  "identifier": "com.kodiakholdings.kodiakconnect",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kodiak Connect",
        "width": 920,
        "height": 560,
        "minWidth": 760,
        "minHeight": 480,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "deb"],
    "publisher": "Kodiak Holdings",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "shortDescription": "Private communication client",
    "longDescription": "Kodiak Connect is a secure communication client for private groups across web, desktop, and Android.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://updates.kodiak-connect.com/manifest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0QzVCMURFRENEMkIxNzIKUldSeXNkTGMzckhGcE8wbVluN3ZkUnpWSFo5TjNuUmdZUEszVnB1Z0J0aHhqaG9Fc3Z1T2lKWUsK"
    }
  }
}
